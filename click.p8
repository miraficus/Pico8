function _init()
 score=0
 cps_score=0
 coinx=84
 coiny=47
 
 strings()
 
 prices()
 
 --debug
 debug_click=0
 menu=0
 
 
end


function _update()
 game_update()

end

function _draw()
 game_draw()
 
end
-->8
-- updates
function game_update()
 -- coin click
 local o=btn(🅾️)
 if debug_click==0 then
  if o and not prev_o then
   score=score+1
  end
 elseif debug_click==1 then
  if btn(🅾️) then
   score=score+1
  end
 end

 prev_o=o

end
-->8
-- draws

function game_draw()
 cls()
 map(0)
 
 -- statistics
 spr(37,88,7)
 spr(37,88,14)
 print(coins..":  ",62,7,0)
 print(cps..":    ",62,14,0)
 print(score,94,7,5)
 print(cps_score.."/s",94,14,5)
 
 
 -- coin
 if btn(🅾️) then
  sspr(32,0,16,16,coinx,coiny)
 else
  sspr(48,0,16,16,coinx,coiny)
 end
 
 -- upgrades
 print(taxes,18,5,0)

 local labels = {
  tithe,
  land,
  market,
  guild,
  gate,
  harbor,
  knight,
  royal
 }

 local y = 15
 local step = 14

 for i=1,#labels do
  print(labels[i], 4, y + (i-1)*step, 0)
 end

 -- cps upgrades
 
 local cpslabels = {
  "+"..ucps1.."/s",
  "+"..ucps2.."/s",
  "+"..ucps3.."/s",
  "+"..ucps4.."/s",
  "+"..ucps5.."/s",
  "+"..ucps6.."/s",
  "+"..ucps7.."/s",
  "+"..ucps8.."/s"
 }

 local cpsy = 21
 local cpsstep = 14

 for cpsi=1,#cpslabels do
  print(cpslabels[cpsi], 10, cpsy + (cpsi-1)*cpsstep, 5)
  spr(37, 4, cpsy + (cpsi-1)*cpsstep + 0)
 end


-- number formatting
function fmt(n)
    if n < 1000 then
        return tostr(n)
    elseif n < 10000 then
        return tostr(flr(n/100)/10).."k"   -- 1.2k
    elseif n < 100000 then
        return tostr(flr(n/100)/10).."k"   -- 12.3k
    elseif n < 1000000 then
        return tostr(flr(n/1000)).."k"     -- 123k, 400k, 999k
    else
        return "999k+"
    end
end

-- prices
local prlabels = {
    up1,
    up2,
    up3,
    up4,
    up5,
    up6,
    up7,
    up8,
}

local pry = 15
local prxt = 58
local prstep = 14

for pri=1,#prlabels do
    local price = fmt(prlabels[pri])
    local w = #price * 4

    spr(37, prxt - w - 6, pry + (pri-1)*prstep)
    print(price, prxt - w, pry + (pri-1)*prstep, 5)
end


